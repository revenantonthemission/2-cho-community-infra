apiVersion: v1
kind: Secret
metadata:
  name: community-secrets
  namespace: app
type: Opaque
stringData:
  DB_PASSWORD: "<change-me>"
  SECRET_KEY: "<change-me>"
  INTERNAL_API_KEY: "<change-me>"
  # SES SMTP 인증 (staging/prod 전용, IAM SMTP 자격 증명)
  SMTP_USER: "<ses-smtp-username>"
  SMTP_PASSWORD: "<ses-smtp-password>"
